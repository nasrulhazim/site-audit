<!-- ViewStats: KPI cards + Chart.js charts -->
<div x-show="$store.audit.activeView === 'stats'" x-data="statsView()" x-init="init()">
  <!-- Empty state -->
  <div x-show="!$store.audit.hasData" class="p-16 text-center" style="color: var(--muted);">
    <p class="text-3xl mb-3">📭</p>
    <p class="text-lg font-medium">No data available for <span x-text="$store.audit.activeState"></span></p>
    <p class="text-sm mt-1" style="color: var(--subtle);">Data for this state has not been contributed yet</p>
  </div>

  <!-- KPI Cards -->
  <div x-show="$store.audit.hasData" class="grid grid-cols-2 md:grid-cols-4 gap-4 p-4">
    <div class="rounded-lg p-4 border" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider" style="color: var(--muted);">Total Sites</p>
      <p class="text-3xl font-bold mt-1" style="color: #3b82f6;" x-text="$store.audit.stats.total"></p>
    </div>
    <div class="rounded-lg p-4 border" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider" style="color: var(--muted);">Illegal</p>
      <p class="text-3xl font-bold mt-1 text-red-500" x-text="$store.audit.stats.byStatus['illegal'] || 0"></p>
    </div>
    <div class="rounded-lg p-4 border" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider" style="color: var(--muted);">Possibly Illegal</p>
      <p class="text-3xl font-bold mt-1 text-orange-500" x-text="$store.audit.stats.byStatus['possibly-illegal'] || 0"></p>
    </div>
    <div class="rounded-lg p-4 border" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider" style="color: var(--muted);">Districts Affected</p>
      <p class="text-3xl font-bold mt-1" style="color: #3b82f6;" x-text="Object.keys($store.audit.stats.byDistrict).length"></p>
    </div>
  </div>

  <!-- Charts row -->
  <div x-show="$store.audit.hasData" class="grid grid-cols-1 md:grid-cols-3 gap-4 px-4 pb-4">
    <!-- Doughnut chart - Status breakdown -->
    <div class="rounded-lg p-4 border" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider mb-3" style="color: var(--muted);">Status Breakdown</p>
      <div style="position: relative; width: 100%;">
        <canvas id="chart-status"></canvas>
      </div>
    </div>

    <!-- Bar chart - By district -->
    <div class="rounded-lg p-4 border md:col-span-2" style="background: var(--surface); border-color: var(--border);">
      <p class="text-xs uppercase tracking-wider mb-3" style="color: var(--muted);">Count by District</p>
      <div style="position: relative; width: 100%;">
        <canvas id="chart-district"></canvas>
      </div>
    </div>
  </div>

  <!-- Category breakdown -->
  <div x-show="$store.audit.hasData" class="px-4 pb-2">
    <p class="text-xs uppercase tracking-wider mb-3" style="color: var(--muted);">By Category</p>
  </div>
  <div x-show="$store.audit.hasData" class="grid grid-cols-2 md:grid-cols-4 gap-4 px-4 pb-4">
    <template x-for="cat in $store.audit.categories" :key="cat">
      <div class="rounded-lg p-4 border text-center" style="background: var(--surface); border-color: var(--border);">
        <p class="text-xs uppercase tracking-wider" style="color: var(--muted);" x-text="cat.replace('-', ' ')"></p>
        <p class="text-2xl font-bold mt-1" style="color: var(--text);"
          x-text="$store.audit.locations.filter(l => l.category === cat).length"
        ></p>
      </div>
    </template>
  </div>

  <!-- Issue breakdown -->
  <div x-show="$store.audit.hasData" class="px-4 pb-2">
    <p class="text-xs uppercase tracking-wider mb-3" style="color: var(--muted);">By Issue</p>
  </div>
  <div x-show="$store.audit.hasData" class="grid grid-cols-2 md:grid-cols-4 gap-4 px-4 pb-4">
    <template x-for="issue in [
      { key: 'no-lot', label: 'No Lot' },
      { key: 'wrong-zoning', label: 'Wrong Zoning' },
      { key: 'restricted-area', label: 'Restricted Area' },
      { key: 'other', label: 'Others' }
    ]" :key="issue.key">
      <div class="rounded-lg p-4 border text-center" style="background: var(--surface); border-color: var(--border);">
        <p class="text-xs uppercase tracking-wider" style="color: var(--muted);" x-text="issue.label"></p>
        <p class="text-2xl font-bold mt-1" style="color: var(--text);"
          x-text="$store.audit.locations.filter(l => l.issues.includes(issue.key)).length"
        ></p>
      </div>
    </template>
  </div>
</div>

<script is:inline>
  function statsView() {
    return {
      statusChart: null,
      districtChart: null,

      init() {
        const rebuild = () => {
          this.destroyCharts()
          if (this.$store.audit.activeView !== 'stats') return
          if (!this.$store.audit.hasData) return
          // Wait for x-show to make parent visible
          setTimeout(() => this.buildCharts(), 100)
        }

        this.$watch('$store.audit.activeView', rebuild)
        this.$watch('$store.audit.dark', rebuild)
        this.$watch('$store.audit.activeState', rebuild)
      },

      buildCharts() {
        if (!this.$store.audit.hasData) return

        const stats = this.$store.audit.stats
        const textColor = this.$store.audit.dark ? '#e2e8f0' : '#0f172a'
        const gridColor = this.$store.audit.dark ? '#334155' : '#e2e8f0'

        // Doughnut chart
        const statusCtx = document.getElementById('chart-status')
        if (statusCtx) {
          this.statusChart = new Chart(statusCtx, {
            type: 'doughnut',
            plugins: [ChartDataLabels],
            data: {
              labels: ['Illegal', 'Possibly Illegal', 'Legal'],
              datasets: [{
                data: [
                  stats.byStatus['illegal'] || 0,
                  stats.byStatus['possibly-illegal'] || 0,
                  stats.byStatus['legal'] || 0,
                ],
                backgroundColor: ['#ef4444', '#f97316', '#22c55e'],
                borderWidth: 0,
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: { color: textColor, font: { family: "'DM Mono', monospace", size: 11 } }
                },
                tooltip: {
                  callbacks: {
                    label: function(context) {
                      const total = context.dataset.data.reduce((a, b) => a + b, 0)
                      const value = context.parsed
                      const pct = total > 0 ? ((value / total) * 100).toFixed(1) : 0
                      return context.label + ': ' + value + ' (' + pct + '%)'
                    }
                  }
                },
                datalabels: {
                  color: '#fff',
                  font: { family: "'DM Mono', monospace", size: 12, weight: 'bold' },
                  formatter: function(value, context) {
                    const total = context.dataset.data.reduce((a, b) => a + b, 0)
                    if (value === 0) return ''
                    const pct = ((value / total) * 100).toFixed(0)
                    return value + '\n' + pct + '%'
                  },
                  textAlign: 'center'
                }
              }
            }
          })
        }

        // Stacked bar chart by district + status
        const districtCtx = document.getElementById('chart-district')
        if (districtCtx) {
          const locations = this.$store.audit.locations
          const districts = Object.keys(stats.byDistrict).sort()

          const countByDistrictStatus = (status) =>
            districts.map(d => locations.filter(l => l.district === d && l.status === status).length)

          this.districtChart = new Chart(districtCtx, {
            type: 'bar',
            plugins: [ChartDataLabels],
            data: {
              labels: districts,
              datasets: [
                {
                  label: 'Illegal',
                  data: countByDistrictStatus('illegal'),
                  backgroundColor: '#ef4444',
                  borderRadius: 2,
                },
                {
                  label: 'Possibly Illegal',
                  data: countByDistrictStatus('possibly-illegal'),
                  backgroundColor: '#f97316',
                  borderRadius: 2,
                },
                {
                  label: 'Legal',
                  data: countByDistrictStatus('legal'),
                  backgroundColor: '#22c55e',
                  borderRadius: 2,
                }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: { color: textColor, font: { family: "'DM Mono', monospace", size: 10 } }
                },
                tooltip: {
                  callbacks: {
                    label: function(context) {
                      return context.dataset.label + ': ' + context.parsed.y
                    }
                  }
                },
                datalabels: {
                  color: '#fff',
                  font: { family: "'DM Mono', monospace", size: 10 },
                  formatter: function(value) {
                    return value > 0 ? value : ''
                  }
                }
              },
              scales: {
                x: {
                  stacked: true,
                  ticks: { color: textColor, font: { family: "'DM Mono', monospace", size: 10 } },
                  grid: { color: gridColor }
                },
                y: {
                  stacked: true,
                  beginAtZero: true,
                  ticks: { color: textColor, stepSize: 1, font: { family: "'DM Mono', monospace", size: 10 } },
                  grid: { color: gridColor }
                }
              }
            }
          })
        }
      },

      destroyCharts() {
        if (this.statusChart) { this.statusChart.destroy(); this.statusChart = null }
        if (this.districtChart) { this.districtChart.destroy(); this.districtChart = null }
      }
    }
  }
</script>
