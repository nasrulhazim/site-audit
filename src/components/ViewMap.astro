<!-- ViewMap: Leaflet map with clustered markers -->
<div x-show="$store.audit.activeView === 'map'" x-data="mapView()" x-init="init()">
  <!-- Empty state -->
  <div x-show="!$store.audit.hasData" class="p-16 text-center" style="color: var(--muted); height: calc(100vh - 130px); display: flex; align-items: center; justify-content: center; flex-direction: column;" :style="!$store.audit.hasData ? '' : 'display:none'">
    <p class="text-3xl mb-3">📭</p>
    <p class="text-lg font-medium">No data available for <span x-text="$store.audit.activeState"></span></p>
    <p class="text-sm mt-1" style="color: var(--subtle);">Data for this state has not been contributed yet</p>
  </div>

  <!-- Mini filter bar -->
  <div x-show="$store.audit.hasData" class="p-3 flex gap-2 items-center border-b" style="border-color: var(--border);">
    <span class="text-xs font-medium" style="color: var(--muted);">Filter:</span>
    <template x-for="s in ['all', 'illegal', 'possibly-illegal', 'legal']" :key="s">
      <button
        class="px-2 py-1 rounded text-xs transition-colors capitalize"
        :class="mapFilter === s ? 'bg-blue-500 text-white' : ''"
        :style="mapFilter !== s ? 'color: var(--muted); background: var(--surface2)' : ''"
        @click="mapFilter = s; updateMarkers()"
        x-text="s === 'all' ? 'All' : s.replace('-', ' ')"
      ></button>
    </template>
  </div>

  <!-- Map container -->
  <div x-show="$store.audit.hasData" id="audit-map" style="height: calc(100vh - 130px); width: 100%;"></div>
</div>

<!-- Custom cluster styles -->
<style is:inline>
  .cluster-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #3b82f6;
    color: #fff;
    font-family: 'DM Mono', monospace;
    font-weight: 400;
    font-size: 14px;
    border: 3px solid rgba(59, 130, 246, 0.4);
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .cluster-small  { width: 36px; height: 36px; }
  .cluster-medium { width: 44px; height: 44px; font-size: 15px; }
  .cluster-large  { width: 52px; height: 52px; font-size: 16px; }
</style>

<script is:inline>
  function mapView() {
    return {
      map: null,
      tileLayer: null,
      clusterGroup: null,
      mapFilter: 'all',

      init() {
        this.$watch('$store.audit.activeView', (val) => {
          if (val === 'map') {
            this.$nextTick(() => {
              if (!this.map) {
                this.createMap()
              }
              this.map.invalidateSize()
              this.updateMarkers()
            })
          }
        })

        // Re-center and update markers when state changes
        this.$watch('$store.audit.activeState', () => {
          if (this.$store.audit.activeView === 'map' && this.map) {
            this.$nextTick(() => {
              const center = this.$store.audit.meta.center
              this.map.setView([center.lat, center.lng], center.zoom)
              this.mapFilter = 'all'
              this.updateMarkers()
            })
          }
        })

        // Switch tile layer when dark mode toggles
        this.$watch('$store.audit.dark', () => {
          if (this.map) {
            this.setTileLayer()
          }
        })
      },

      getTileUrl() {
        return this.$store.audit.dark
          ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
          : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png'
      },

      getTileAttribution() {
        return this.$store.audit.dark
          ? '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>'
          : '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
      },

      setTileLayer() {
        if (this.tileLayer) this.map.removeLayer(this.tileLayer)
        this.tileLayer = L.tileLayer(this.getTileUrl(), {
          attribution: this.getTileAttribution()
        }).addTo(this.map)
      },

      createMap() {
        const center = this.$store.audit.meta.center
        this.map = L.map('audit-map').setView([center.lat, center.lng], center.zoom)
        this.setTileLayer()
        this.clusterGroup = L.markerClusterGroup({
          iconCreateFunction: function(cluster) {
            const count = cluster.getChildCount()
            let size = 'small'
            if (count >= 10) size = 'medium'
            if (count >= 25) size = 'large'
            return L.divIcon({
              html: '<div class="cluster-icon cluster-' + size + '">' + count + '</div>',
              className: '',
              iconSize: L.point(size === 'small' ? 36 : size === 'medium' ? 44 : 52, size === 'small' ? 36 : size === 'medium' ? 44 : 52)
            })
          }
        })
        this.map.addLayer(this.clusterGroup)
        this.updateMarkers()
      },

      updateMarkers() {
        if (!this.clusterGroup) return
        this.clusterGroup.clearLayers()

        const locations = this.$store.audit.locations.filter(l =>
          this.mapFilter === 'all' || l.status === this.mapFilter
        )

        const colors = { illegal: '#ef4444', 'possibly-illegal': '#f97316', legal: '#22c55e' }

        locations.forEach(loc => {
          const color = colors[loc.status] || '#3b82f6'
          const icon = L.divIcon({
            className: '',
            html: `<div style="width:22px;height:22px;border-radius:50%;background:${color};border:3px solid rgba(255,255,255,0.9);box-shadow:0 2px 8px rgba(0,0,0,.5);"></div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11],
          })

          const statusLabel = loc.status.replace('-', ' ')
          const badgeColor = loc.status === 'illegal' ? '#ef4444'
            : loc.status === 'possibly-illegal' ? '#f97316' : '#22c55e'

          const popup = `
            <div style="font-family:'DM Mono',monospace;font-size:12px;min-width:180px">
              <strong>${loc.name}</strong><br/>
              <span style="color:#64748b">${loc.address}</span><br/>
              <span style="display:inline-block;margin-top:4px;padding:2px 6px;border-radius:9999px;font-size:10px;color:white;background:${badgeColor}">${statusLabel}</span><br/>
              <span style="color:#94a3b8;font-size:10px;margin-top:4px;display:inline-block">${loc.lat.toFixed(4)}, ${loc.lng.toFixed(4)}</span>
            </div>
          `

          L.marker([loc.lat, loc.lng], { icon }).bindPopup(popup).addTo(this.clusterGroup)
        })
      }
    }
  }
</script>
