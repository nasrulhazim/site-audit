<!-- ViewSearch: search bar, filters, data table -->
<div x-show="$store.audit.activeView === 'search'" x-data>
  <!-- Filters bar -->
  <div x-show="$store.audit.hasData" class="p-4 flex flex-wrap gap-3 items-center border-b" style="border-color: var(--border);">
    <!-- Search input -->
    <input
      type="text"
      placeholder="Search name or address..."
      class="px-3 py-2 rounded border text-sm flex-1 min-w-[200px] outline-none focus:ring-2 focus:ring-blue-500/40"
      style="background: var(--input-bg); border-color: var(--border); color: var(--text);"
      x-model="$store.audit.search"
    />

    <!-- District filter -->
    <select
      class="px-3 py-2 rounded border text-sm outline-none"
      style="background: var(--input-bg); border-color: var(--border); color: var(--text);"
      x-model="$store.audit.filterDistrict"
    >
      <option value="all">All Districts</option>
      <template x-for="d in $store.audit.districts" :key="d">
        <option :value="d" x-text="d"></option>
      </template>
    </select>

    <!-- Status filter -->
    <select
      class="px-3 py-2 rounded border text-sm outline-none"
      style="background: var(--input-bg); border-color: var(--border); color: var(--text);"
      x-model="$store.audit.filterStatus"
    >
      <option value="all">All Status</option>
      <option value="illegal">Illegal</option>
      <option value="possibly-illegal">Possibly Illegal</option>
      <option value="legal">Legal</option>
    </select>

    <!-- Category filter -->
    <select
      class="px-3 py-2 rounded border text-sm outline-none"
      style="background: var(--input-bg); border-color: var(--border); color: var(--text);"
      x-model="$store.audit.filterCategory"
    >
      <option value="all">All Categories</option>
      <template x-for="c in $store.audit.categories" :key="c">
        <option :value="c" x-text="c.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')"></option>
      </template>
    </select>

    <!-- Record count -->
    <span
      class="px-2 py-1 rounded text-xs font-medium"
      style="background: var(--surface2); color: var(--muted);"
      x-text="$store.audit.filtered.length + ' records'"
    ></span>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full text-sm" style="border-collapse: collapse;">
      <thead>
        <tr style="background: var(--thead);">
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">No</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Name</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Address</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">District</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Category</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Status</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Issues</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Links</th>
          <th class="px-3 py-2 text-left text-xs font-medium uppercase tracking-wider" style="color: var(--muted);">Coordinates</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="(loc, i) in $store.audit.filtered" :key="loc.id">
          <tr class="border-b transition-colors" style="border-color: var(--border);"
              :style="'&:hover { background: var(--row-hover) }'"
              onmouseenter="this.style.background='var(--row-hover)'"
              onmouseleave="this.style.background='transparent'"
          >
            <td class="px-3 py-2" style="color: var(--muted);" x-text="i + 1"></td>
            <td class="px-3 py-2 font-medium" x-text="loc.name"></td>
            <td class="px-3 py-2" style="color: var(--muted);" x-text="loc.address"></td>
            <td class="px-3 py-2" x-text="loc.district"></td>
            <td class="px-3 py-2" x-text="loc.category.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')"></td>
            <td class="px-3 py-2">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium"
                :class="{
                  'bg-red-900 text-red-300': loc.status === 'illegal' && $store.audit.dark,
                  'bg-red-100 text-red-700': loc.status === 'illegal' && !$store.audit.dark,
                  'bg-orange-900 text-orange-300': loc.status === 'possibly-illegal' && $store.audit.dark,
                  'bg-orange-100 text-orange-700': loc.status === 'possibly-illegal' && !$store.audit.dark,
                  'bg-green-900 text-green-300': loc.status === 'legal' && $store.audit.dark,
                  'bg-green-100 text-green-700': loc.status === 'legal' && !$store.audit.dark,
                }"
                x-text="loc.status.replace('-', ' ')"
              ></span>
            </td>
            <td class="px-3 py-2">
              <div class="flex flex-wrap gap-1">
                <template x-for="issue in loc.issues" :key="issue">
                  <span class="px-1.5 py-0.5 rounded text-[10px]" style="background: var(--surface2); color: var(--muted);" x-text="issue"></span>
                </template>
                <span x-show="loc.issues.length === 0" class="text-xs" style="color: var(--subtle);">—</span>
              </div>
            </td>
            <td class="px-3 py-2">
              <div class="flex flex-wrap gap-1">
                <template x-for="link in (loc.links || [])" :key="link.url">
                  <a :href="link.url" target="_blank" rel="noopener"
                    class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] hover:opacity-80 transition-opacity"
                    style="background: var(--surface2); color: var(--muted);"
                    :title="link.label || link.url">
                    <span x-text="link.label || (() => {
                      const u = link.url.toLowerCase();
                      if (u.includes('facebook.com') || u.includes('fb.com')) return 'FB';
                      if (u.includes('x.com') || u.includes('twitter.com')) return 'X';
                      if (u.includes('instagram.com')) return 'IG';
                      if (u.includes('tiktok.com')) return 'TikTok';
                      if (u.includes('youtube.com') || u.includes('youtu.be')) return 'YT';
                      return 'Link';
                    })()"></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                </template>
                <span x-show="!loc.links || loc.links.length === 0" class="text-xs" style="color: var(--subtle);">—</span>
              </div>
            </td>
            <td class="px-3 py-2 text-xs whitespace-nowrap" style="color: var(--subtle);" x-text="loc.lat.toFixed(4) + ', ' + loc.lng.toFixed(4)"></td>
          </tr>
        </template>
      </tbody>
    </table>

    <!-- Empty state: no data for state -->
    <div x-show="!$store.audit.hasData" class="p-16 text-center" style="color: var(--muted);">
      <p class="text-3xl mb-3">📭</p>
      <p class="text-lg font-medium">No data available for <span x-text="$store.audit.activeState"></span></p>
      <p class="text-sm mt-1" style="color: var(--subtle);">Data for this state has not been contributed yet</p>
    </div>

    <!-- Empty state: no results from filters -->
    <div x-show="$store.audit.hasData && $store.audit.filtered.length === 0" class="p-12 text-center" style="color: var(--muted);">
      <p class="text-lg">No results found</p>
      <p class="text-sm mt-1">Try adjusting your search or filters</p>
    </div>
  </div>
</div>
