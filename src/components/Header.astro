<!-- Header: logo, view tabs, dark mode toggle -->
<div x-data class="sticky top-0 z-50">
  <header
    class="border-b px-4 py-3 flex items-center justify-between gap-4 flex-wrap"
    style="background: linear-gradient(135deg, var(--hdr-from), var(--hdr-to)); border-color: var(--border);"
  >
    <!-- Logo -->
    <img x-show="$store.audit.dark" src="/logo-dark.svg" alt="siteaudit" style="height: 32px;">
    <img x-show="!$store.audit.dark" src="/logo-light.svg" alt="siteaudit" style="height: 32px;">

    <!-- View Tabs -->
    <nav class="flex gap-1">
      <template x-for="tab in ['search', 'map', 'stats']">
        <button
          class="px-3 py-1.5 rounded text-xs font-medium uppercase tracking-wider transition-colors"
          :class="$store.audit.activeView === tab
            ? 'bg-blue-500 text-white'
            : 'hover:bg-blue-500/10'"
          style="color: var(--text);"
          :style="$store.audit.activeView === tab ? 'color: white' : ''"
          @click="$store.audit.activeView = tab"
          x-text="tab"
        ></button>
      </template>
    </nav>

    <!-- Dark Mode Toggle -->
    <button
      class="p-2 rounded-lg transition-colors hover:bg-blue-500/10"
      @click="$store.audit.toggleDark()"
      :title="$store.audit.dark ? 'Switch to light mode' : 'Switch to dark mode'"
    >
      <svg x-show="$store.audit.dark" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
      <svg x-show="!$store.audit.dark" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
  </header>

  <!-- State selector bar -->
  <div
    class="px-4 py-2 flex items-center gap-3 border-b text-xs"
    style="background: var(--surface); border-color: var(--border);"
  >
    <span style="color: var(--muted);">State</span>
    <div class="flex gap-1 flex-wrap">
      <template x-for="state in $store.audit.allStates" :key="state">
        <button
          class="px-3 py-1 rounded transition-colors"
          :class="{
            'bg-blue-500 text-white': $store.audit.activeState === state,
            'opacity-40': !$store.audit._stateMap[state] && $store.audit.activeState !== state
          }"
          :style="$store.audit.activeState !== state ? 'color: var(--muted); background: var(--surface2)' : ''"
          @click="$store.audit.switchState(state)"
          x-text="state"
        ></button>
      </template>
    </div>
    <span class="ml-auto" style="color: var(--subtle);" x-text="$store.audit.locations.length + ' sites'"></span>
  </div>
</div>
